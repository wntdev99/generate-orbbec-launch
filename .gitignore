# Generated launch files are host-specific (USB ports / serials) -> not tracked.
# Remove this rule if you want to commit a particular generated launch file.
/launch/*.launch.py
# ...but the hand-authored monitor launch files ARE tracked.
!/launch/monitors.launch.py
!/launch/wifi_wan_monitor.launch.py
!/launch/link_latency.launch.py
!/launch/net_throughput_monitor.launch.py
!/launch/router_throughput_monitor.launch.py
!/launch/all.launch.py

# ROS 2 / colcon build artifacts
/build/
/install/
/log/

# Python
__pycache__/
*.pyc
